<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- request search engine to not index if post has hidden tag -->
    {{#post}}
        {{#has tag="#hidden"}}
            <meta name="robots" content="noindex, nofollow">
        {{/has}}
    {{/post}}

    <title>{{meta_title}}</title>

    {{!-- Preload critical resources to reduce render-blocking --}}
    <link rel="preload" as="style" href="{{asset "built/screen.css"}}" />
    <link rel="preload" as="script" href="{{asset "built/main.min.js"}}" />
    {{#is "home"}}
        {{#if @site.cover_image}}
            {{#match @custom.header_section_layout "Large background"}}
                <link rel="preload" as="image" href="{{@site.cover_image}}">
            {{else match @custom.header_section_layout "Side by side"}}
                <link rel="preload" as="image" href="{{img_url @site.cover_image size="m"}}">
            {{/match}}
        {{/if}}
    {{/is}}
     
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.12.3/tocbot.css">
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>
        :root {
            --background-color: {{@custom.default_background_color}};
            --dark-mode-background-color: {{@custom.dark_mode_background_color}};
        }

        .gh-content {
            position: relative;
        }
    </style>

    <script>
        var originalBackgroundColor = getComputedStyle(document.documentElement).getPropertyValue('--background-color');
    </script>
    <script src="{{asset "js/theme-head.js"}}"></script>
    <script>
        // Initialize theme and event listeners after DOM is ready
        document.addEventListener("DOMContentLoaded", function () {
            // Initial run to load dark mode preference
            originalAccentColor = getComputedStyle(document.documentElement).getPropertyValue('--ghost-accent-color');

            // determine the shade of the current accent color for contrast adjustment in theme switching
            var accentColor = originalAccentColor.trim().slice(1);
            var r = parseInt(accentColor.substr(0, 2), 16);
            var g = parseInt(accentColor.substr(2, 2), 16);
            var b = parseInt(accentColor.substr(4, 2), 16);
            var yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
            originalAccentColorShade = (yiq >= 128) ? 'bright' : 'dim';

            initColorTheme();



            // Event listener: Automatically change theme if system preference changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
                if (localStorage.getItem('autoDarkMode') === 'true') {
                    var newColorScheme = e.matches ? 'dark' : 'light';
                    changeColorTheme(newColorScheme);
                }
            });
        });
    </script>
    
    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.typography "Elegant serif"}} has-serif-font{{/match}}{{#match @custom.typography "Consistent mono"}} has-mono-font{{/match}}{{#match @custom.post_feed_layout "Classic"}} has-classic-feed{{/match}}{{#match @custom.post_feed_layout "Typographic"}} has-typographic-feed{{/match}}{{#match @custom.post_feed_layout "Parallax"}} has-parallax-feed{{/match}}">
<div class="gh-site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img srcset="{{img_url @site.logo size="s"}} 300w,
                                {{img_url @site.logo size="m"}} 720w"
                                sizes="90vw"
                            src="{{img_url @site.logo size="s"}}" alt="{{@site.title}}"
                            >
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>
                </div>
                <button class="gh-search gh-icon-btn gh-has-tooltip" id="theme-button" aria-label="Toggle theme" onclick="changeColorTheme()">
                    <div class="icon-system">
                        {{> "icons/half-sun-moon"}}
                    </div>
                    <div class="icon-moon">
                        {{> "icons/moon"}}
                    </div>
                    <div class="icon-sun">
                        {{> "icons/sun"}}
                    </div>
                    <span class="gh-icon-tooltip">Theme</span>
                </button>
                <button class="gh-search gh-icon-btn gh-has-tooltip" id="search-button" aria-label="Search this site" data-ghost-search>{{> "icons/search"}}<span class="gh-icon-tooltip">Search</span></button>
                {{#if @site.navigation}}
                    <button class="gh-burger gh-has-tooltip" aria-label="Toggle menu"><span class="gh-icon-tooltip">Menu</span></button>
                {{/if}}
            </div>

            <nav class="gh-head-menu">
                {{navigation}}
                {{#unless @site.members_enabled}}
                    {{#match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn gh-has-tooltip" id="search-button" aria-label="Search this site" data-ghost-search>{{> "icons/search"}}<span class="gh-icon-tooltip">Search</span></button>
                        <button class="gh-search gh-icon-btn gh-has-tooltip" id="theme-button" aria-label="Toggle site theme" onclick="changeColorTheme()">
                            <div class="icon-system">
                                {{> "icons/half-sun-moon"}}
                            </div>
                            <div class="icon-moon">
                                {{> "icons/moon"}}
                            </div>
                            <div class="icon-sun">
                                {{> "icons/sun"}}
                            </div>
                            <span class="gh-icon-tooltip">Theme</span>
                        </button>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                <button class="gh-search gh-icon-btn gh-has-tooltip" id="theme-button" aria-label="Toggle theme" onclick="changeColorTheme()">
                    <div class="icon-system">
                        {{> "icons/half-sun-moon"}}
                    </div>
                    <div class="icon-moon">
                        {{> "icons/moon"}}
                    </div>
                    <div class="icon-sun">
                        {{> "icons/sun"}}
                    </div>
                    <span class="gh-icon-tooltip">Theme</span>
                </button>
                <button class="gh-search gh-icon-btn gh-has-tooltip" id="search-button" aria-label="Search this site" data-ghost-search>{{> "icons/search"}}<span class="gh-icon-tooltip">Search</span></button>
                {{#match @custom.show_account_on_header "Only when logged in"}}
                    {{#if @member}}
                        <div class="gh-head-members">
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">Account</a>
                        </div>
                    {{/if}}
                {{else match @custom.show_account_on_header "Always"}}
                    <div class="gh-head-members">
                        {{#unless @member}}
                            {{#unless @site.members_invite_only}}
                                <a class="gh-head-link" href="#/portal/signin" data-portal="signin">Sign in</a>
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signup" data-portal="signup">Subscribe</a>
                            {{else}}
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">Sign in</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">Account</a>
                        {{/unless}}
                    </div>
                {{/match}}
            </div>
        </div>
    </header>

    {{{body}}}

    {{! Initialize Tocbot after you load the script }}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.12.3/tocbot.min.js"></script>


    <footer class="gh-foot gh-outer">
        <div class="gh-foot-inner gh-inner">
            <nav class="gh-foot-menu">
                {{navigation type="secondary"}}
            </nav>

            <div class="gh-copyright">
                {{#unless @custom.footer_text}}
                    {{@site.title}} © {{date format="YYYY"}}. Powered by <a href="https://ghost.org/" target="_blank" rel="noopener">Ghost</a>
                {{else}}
                    {{@custom.footer_text}}
                {{/unless}}
            </div>
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var burgers = document.querySelectorAll('.gh-burger');
        burgers.forEach(function (burger) {
            var tooltip = burger.querySelector('.gh-icon-tooltip');
            if (!tooltip) return;
            
            burger.addEventListener('click', function () {
                setTimeout(function () {
                    var isOpen = document.documentElement.classList.contains('is-head-open') || document.body.classList.contains('is-head-open');
                    var newText = isOpen ? 'Close' : 'Menu';
                    
                    tooltip.classList.add('is-updating');
                    setTimeout(function () {
                        tooltip.textContent = newText;
                        tooltip.classList.remove('is-updating');
                    }, 200);
                }, 10);
            });
        });
    });
</script>

{{ghost_foot}}

</body>

</html>

{
    "name": "solorium",
    "description": "A custom Ghost theme focused on personal blogging and imagery, with a clean and modern design.",
    "version": "1.0.10",
    "engines": {
        "ghost": ">=6.0.0"
    },
    "license": "MIT",
    "author": {
        "name": "Quang Nguyen",
        "email": "support@quangmn.com",
        "url": "https://quangmn.com"
    },
    "keywords": [
        "ghost",
        "theme",
        "blog",
        "personal"
    ],
    "docs": "https://solo.ghost.io/about/",
    "config": {
        "posts_per_page": 8,
        "image_sizes": {
            "xs": {
                "width": 150
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 720
            },
            "l": {
                "width": 960
            },
            "xl": {
                "width": 1200
            },
            "xxl": {
                "width": 2000
            }
        },
        "card_assets": true,
        "custom": {
            "default_background_color": {
                "type": "color",
                "default": "#fefefa"
            },
            "dark_mode_background_color": {
                "type": "color",
                "default": "#000000"
            },
            "show_table_of_contents_in_pages": {
                "type": "boolean",
                "default": true
            },
            "navigation_layout": {
                "type": "select",
                "options": ["Logo on the left", "Logo in the middle", "Stacked"],
                "default": "Logo in the middle"
            },
            "show_account_on_header": {
                "type": "select",
                "options": ["Always", "Only when logged in", "Never"],
                "default": "Always"
            },
            "typography": {
                "type": "select",
                "options": ["Modern sans-serif", "Elegant serif", "Consistent mono"],
                "default": "Modern sans-serif"
            },
            "footer_text": {
                "type": "text"
            },

            "show_share_button": {
                "type": "boolean",
                "default": true,
                "group": "post"
            },
            "show_table_of_contents_in_posts": {
                "type": "boolean",
                "default": false,
                "group": "post"
            },

            "primary_header": {
                "type": "text",
                "default": "Welcome to Solorium",
                "group": "homepage"
            },
            "secondary_header": {
                "type": "text",
                "default": "BOTTOM TEXT",
                "group": "homepage"
            },
            "header_section_layout": {
                "type": "select",
                "options": ["Side by side", "Large background", "Typographic profile"],
                "default": "Large background",
                "group": "homepage"
            },  
            "post_feed_layout": {
                "type": "select",
                "options": ["Classic", "Typographic", "Parallax"],
                "default": "Classic",
                "group": "homepage"
            },
            "show_restricted_posts": {
                "type": "boolean",
                "default": false,
                "group": "homepage"
            }
        }
    },
    "scripts": {
        "dev": "gulp",
        "test": "gscan .",
        "zip": "gulp zip"
    },
    "devDependencies": {
        "@tryghost/shared-theme-assets": "2.6.1",
        "@tryghost/theme-translations": "^0.0.9",
        "autoprefixer": "10.5.0",
        "beeper": "2.1.0",
        "cssnano": "7.1.7",
        "gscan": "5.4.3",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.12",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4"
    }
}

